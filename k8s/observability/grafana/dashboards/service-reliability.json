{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "AMP Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "service_name",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(otel_calls_total, service_name)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Overview / Golden Signals",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Total Request Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(otel_calls_total{span_kind=\"SPAN_KIND_SERVER\", service_name=~\"$service_name\", span_name!~\".*TraceService/Export.*|.*Health/Check.*\"}[5m]))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "title": "Latency p95",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(otel_duration_milliseconds_bucket{span_kind=\"SPAN_KIND_SERVER\", service_name=~\"$service_name\", span_name!~\".*TraceService/Export.*|.*Health/Check.*\"}[5m])) by (le))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "orange", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "title": "Error Rate %",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(otel_calls_total{span_kind=\"SPAN_KIND_SERVER\", service_name=~\"$service_name\", status_code=\"STATUS_CODE_ERROR\", span_name!~\".*TraceService/Export.*|.*Health/Check.*\"}[5m])) or vector(0)) / sum(rate(otel_calls_total{span_kind=\"SPAN_KIND_SERVER\", service_name=~\"$service_name\", span_name!~\".*TraceService/Export.*|.*Health/Check.*\"}[5m])) * 100",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "title": "Active Services",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(count by (service_name) (rate(otel_calls_total{span_kind=\"SPAN_KIND_SERVER\", span_name!~\".*TraceService/Export.*|.*Health/Check.*\"}[5m]) > 0))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null },
              { "color": "blue", "value": 3 },
              { "color": "green", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "type": "row",
      "title": "Errors",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Error Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(otel_calls_total{span_kind=\"SPAN_KIND_SERVER\", service_name=~\"$service_name\", status_code=\"STATUS_CODE_ERROR\", span_name!~\".*TraceService/Export.*|.*Health/Check.*\"}[5m])) by (service_name)",
          "legendFormat": "{{service_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50,
            "stacking": { "mode": "normal" }
          },
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "title": "Error Rate % by Endpoint",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(otel_calls_total{span_kind=\"SPAN_KIND_SERVER\", service_name=~\"$service_name\", status_code=\"STATUS_CODE_ERROR\", span_name!~\".*TraceService/Export.*|.*Health/Check.*\"}[5m])) by (service_name, span_name) or vector(0)) / sum(rate(otel_calls_total{span_kind=\"SPAN_KIND_SERVER\", service_name=~\"$service_name\", span_name!~\".*TraceService/Export.*|.*Health/Check.*\"}[5m])) by (service_name, span_name) * 100",
          "legendFormat": "",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "align": "auto", "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Error %" },
              { "id": "unit", "value": "percent" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 1 },
                    { "color": "orange", "value": 5 },
                    { "color": "red", "value": 10 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Error %", "desc": true }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "service_name": "Service",
              "span_name": "Endpoint"
            },
            "excludeByName": { "__name__": true }
          }
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["warhammer", "reliability", "otel"],
  "time": { "from": "now-30m", "to": "now" },
  "title": "Warhammer 40k - Service Reliability",
  "uid": "wh40k-reliability"
}